<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đổi mật khẩu - EduPress</title>
    <link rel="stylesheet" href="index.css">
    <link rel="stylesheet" href="auth.css">
    <link rel="stylesheet" href="information.css">
    <link rel="stylesheet" href="change-password.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <header class="navbar">
        <a href="index.html" class="logo">
          <img src="logo.png" alt="EduPress logo">
        </a>
        <nav class="menu">
            <a href="index.html">Home</a>
            <a href="course-listing.html">Courses</a>
            <a href="Blogs.html">Blogs</a>
            <a href="contact.html">Contact</a>
        </nav>
        <div class="auth">
        </div>
    </header>

    <main class="profile-container">
        <aside class="profile-sidebar">
            <ul>
                <li><a href="information.html"><i class="fa-solid fa-user-pen"></i> Thông tin & liên hệ</a></li>
                <li><a href="change-password.html" class="active"><i class="fa-solid fa-lock"></i> Đổi mật khẩu</a></li>
            </ul>
        </aside>

        <section class="profile-content">
            <div class="profile-card">
                <div class="card-header">
                    <h3>Thay đổi mật khẩu</h3>
                </div>
                <div class="card-body">
                    <form id="changePasswordForm">
                        <div class="form-group">
                            <label for="currentPassword">Mật khẩu cũ</label>
                            <div class="password-group">
                                <input type="password" id="currentPassword" required>
                                <i class="fa-solid fa-eye-slash toggle-password"></i>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="newPassword">Mật khẩu mới</label>
                            <div class="password-group">
                                <input type="password" id="newPassword" required>
                                <i class="fa-solid fa-eye-slash toggle-password"></i>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="confirmPassword">Nhập lại mật khẩu mới</label>
                            <div class="password-group">
                                <input type="password" id="confirmPassword" required>
                                <i class="fa-solid fa-eye-slash toggle-password"></i>
                            </div>
                        </div>

                        <div id="passwordMessage" class="message"></div>
                        
                        <div class="form-actions">
                            <a href="forgot-password.html" class="forgot-link">Quên mật khẩu?</a>
                            <button type="submit" class="submit-btn">Lưu</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>© 2025 EduPress. All rights reserved.</p>
    </footer>

    <script src="auth.js"></script>
    <script src="change-password.js"></script>
</body>
</html>

